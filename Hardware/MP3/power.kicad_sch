				(size 1.27 1.27)
			)
		)
		(uuid "63ddc678-c081-45bc-94b9-ffaa5c935a33")
	)
	(text "MCP73871-1CC\n-2 means charges up to 4.2V\nfirst C means has 6 hour safety timer for charging\nsecond C means 3.1V Low battery threshold"
